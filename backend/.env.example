# Backend type: "bitcoin_core" or "electrum"
BACKEND_TYPE=bitcoin_core

# Bitcoin Core RPC settings
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=38332
BITCOIN_RPC_USER=your_rpc_username
BITCOIN_RPC_PASSWORD=your_rpc_password

# Electrum server (only used when BACKEND_TYPE=electrum)
ELECTRUM_HOST=127.0.0.1
ELECTRUM_PORT=50001
ELECTRUM_SSL=false

# App settings
DEBUG=false
MAX_TRAVERSAL_DEPTH=10

# CORS origins
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173","http://localhost:8080"]
